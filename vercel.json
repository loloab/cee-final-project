{
  "installCommand": "npm install && npm install --prefix client",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/(.)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "includeFiles": "server/**"
    }
  }
}